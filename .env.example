# Copie este arquivo para .env e preencha os valores.
# (cp .env.example .env)

# URL do PostgreSQL (precisa da extensão pgvector). Ex.: Neon, Supabase, local.
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?sslmode=require"

# Segredo para assinar os tokens de sessão (JWT). Gere um valor próprio com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# (Opcional) Chave da Resend para enviar e-mails de redefinição de senha.
# Sem ela, o link de redefinição é apenas registrado no console do servidor.
RESEND_API_KEY=""

# (Opcional) Remetente dos e-mails. Padrão: "Vote Consciente <onboarding@resend.dev>"
EMAIL_FROM=""
