generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Usuario {
  id               String        @id @default(uuid())
  email            String?       @unique
  perfilIdeologico String?       @map("perfil_ideologico")
  dataCriacao      DateTime      @default(now()) @map("data_criacao")
  votos            VotoUsuario[]

  @@map("usuario")
}

model Proposicao {
  id                Int                          @id
  siglaTipo         String                       @map("sigla_tipo")
  numero            Int
  ano               Int
  numOficial        String                       @map("num_oficial")
  dataApresentacao  DateTime?                    @map("data_apresentacao")
  statusDescricao   String?                      @map("status_descricao")
  idSituacao        Int?                         @map("id_situacao")
  apelidoIa         String?                      @map("apelido_ia")
  keywords          String? // Ex: "redução, jornada de trabalho, qualidade de vida"
  ementaOficial     String                       @map("ementa_oficial")
  resumoCidadao     String?                      @map("resumo_cidadao")
  categoria         String?
  rankingRelevancia Int                          @default(0) @map("ranking_relevancia")
  // Provenância da votação escolhida para exibição (resultado definitivo vs. parcial).
  // Ver vault/data-sources/06_voting_definitive.md.
  votacaoId         String?                      @map("votacao_id")
  votacaoStage      String?                      @map("votacao_stage") // descrição/etapa da sessão exibida
  votacaoFinalizada Boolean                      @default(false) @map("votacao_finalizada")
  votacaoData       DateTime?                    @map("votacao_data")
  // Using Unsupported for pgvector type. Prisma supports it via raw queries.
  embedding         Unsupported("vector(1536)")?
  votosUsuarios     VotoUsuario[]
  votosParlamentar  VotoParlamentar[]
  autores           ProposicaoAutor[]

  @@map("proposicao")
}

model Parlamentar {
  id            Int                     @id
  nomeEleitoral String                  @map("nome_eleitoral")
  partido       String
  uf            String
  statusMandato String                  @map("status_mandato")
  urlFoto       String?                 @map("url_foto")
  matchGlobal   Float?                  @map("match_global")
  // false = parlamentar de legislatura anterior, mantido apenas para aparecer em
  // votações históricas (nome+foto+partido). Não recebe dados completos. Ver
  // vault/data-sources/06_voting_definitive.md.
  ativo         Boolean                 @default(true)
  votos         VotoParlamentar[]
  despesas      Despesa[]
  comissoes     CargoComissao[]
  proposicoes   ProposicaoAutor[]

  @@map("parlamentar")
}

model ProposicaoAutor {
  id            String @id @default(uuid())
  proposicaoId  Int    @map("proposicao_id")
  parlamentarId Int    @map("parlamentar_id")

  proposicao  Proposicao  @relation(fields: [proposicaoId], references: [id])
  parlamentar Parlamentar @relation(fields: [parlamentarId], references: [id])

  @@unique([proposicaoId, parlamentarId])
  @@map("proposicao_autor")
}

model CargoComissao {
  id            String    @id @default(uuid())
  parlamentarId Int       @map("parlamentar_id")
  orgao         String
  siglaOrgao    String    @map("sigla_orgao")
  tituloCargo   String    @map("titulo_cargo")
  dataInicio    DateTime? @map("data_inicio")

  parlamentar Parlamentar @relation(fields: [parlamentarId], references: [id])

  @@map("cargo_comissao")
}

model VotoUsuario {
  id           String   @id @default(uuid())
  usuarioId    String   @map("usuario_id")
  proposicaoId Int      @map("proposicao_id")
  voto         String // SIM, NAO, PULAR
  dataVoto     DateTime @default(now()) @map("data_voto")

  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  proposicao Proposicao @relation(fields: [proposicaoId], references: [id])

  @@unique([usuarioId, proposicaoId])
  @@map("voto_usuario")
}

model VotoParlamentar {
  id            String   @id @default(uuid())
  parlamentarId Int      @map("parlamentar_id")
  proposicaoId  Int      @map("proposicao_id")
  voto          String // SIM, NAO, ABSTENCAO, OBSTRUCAO
  dataVoto      DateTime @map("data_voto")

  parlamentar Parlamentar @relation(fields: [parlamentarId], references: [id])
  proposicao  Proposicao  @relation(fields: [proposicaoId], references: [id])

  @@unique([parlamentarId, proposicaoId])
  @@map("voto_parlamentar")
}

model Despesa {
  id            String @id @default(uuid())
  parlamentarId Int    @map("parlamentar_id")
  tipoMesAno    String @map("tipo_mes_ano")
  valor         Float

  parlamentar Parlamentar @relation(fields: [parlamentarId], references: [id])

  @@map("despesa")
}

// Tabela de resultados AGREGADOS por sessão de votação, mantida por outra pessoa do
// time (pipeline paralelo). Modelada aqui só para o Prisma reconhecê-la e NÃO removê-la
// em `db push`. Sem relação/FK de propósito para não alterar a tabela existente.
// Não usada pelo código deste app. Ver vault/data-sources/06_voting_definitive.md.
model Votacao {
  id           String    @id
  proposicaoId Int       @map("proposicao_id")
  descricao    String
  tipo         String?
  dataHoraVoto DateTime  @map("data_hora_voto")
  votosNao     Int       @map("votos_nao")
  votosOutros  Int       @map("votos_outros")
  votosSim     Int       @map("votos_sim")
  orgao        String?

  @@map("votacao")
}
